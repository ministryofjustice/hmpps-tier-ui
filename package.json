{
  "name": "hmpps-tier-ui",
  "version": "0.0.1",
  "description": "HMPPS Tier UI",
  "repository": "git@github.com:ministryofjustice/hmpps-tier-ui.git",
  "license": "MIT",
  "scripts": {
    "prepare": "hmpps-precommit-hooks-prepare",
    "watch-ts": "tsc -w",
    "build": "node esbuild/esbuild",
    "start": "node $NODE_OPTIONS dist/server.js | bunyan -o short",
    "start:dev": "node esbuild/esbuild --watch",
    "start-feature:dev": "concurrently -k -p \"[{name}]\" -n \"ESBuild,WireMock\" -c \"magenta.bold,cyan.bold\" \"node esbuild/esbuild --watch --env feature.env\" \"npm run wiremock\"",
    "wiremock": "npx wiremock --port 9091 --root-dir wiremock --local-response-templating",
    "lint": "eslint . --cache --max-warnings 0",
    "lint-fix": "eslint . --cache --max-warnings 0 --fix",
    "typecheck": "tsc && tsc -p integration_tests",
    "test": "jest",
    "test:ci": "jest --runInBand",
    "security_audit": "npx audit-ci --config audit-ci.json",
    "int-test": "cypress run --config video=false",
    "int-test-ui": "cypress open --e2e --browser chrome",
    "clean": "rm -rf dist build node_modules stylesheets",
    "rebuild": "npm run clean && npm run setup && npm run build",
    "setup": "npm ci && hmpps-npm-script-run-allowlist"
  },
  "engines": {
    "node": "^24",
    "npm": "^11"
  },
  "dependencies": {
    "@flipt-io/flipt-client-js": "0.4.2",
    "@ministryofjustice/frontend": "^9.0.0",
    "@ministryofjustice/hmpps-arns-frontend-components-lib": "1.1.4",
    "@ministryofjustice/hmpps-audit-client": "^1.1.1",
    "@ministryofjustice/hmpps-auth-clients": "^1.0.2",
    "@ministryofjustice/hmpps-monitoring": "^1.0.2",
    "@ministryofjustice/hmpps-probation-frontend-components": "^1.0.2",
    "@ministryofjustice/hmpps-rest-client": "^1.2.0",
    "@ministryofjustice/probation-search-frontend": "^4.1.0",
    "applicationinsights": "^2.9.8",
    "body-parser": "^2.2.2",
    "bunyan": "^1.8.15",
    "bunyan-format": "^0.2.1",
    "compression": "^1.8.1",
    "connect-flash": "^0.1.1",
    "connect-redis": "^9.0.0",
    "csrf-sync": "^4.2.1",
    "date-fns": "^4.1.0",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "govuk-frontend": "^6.1.0",
    "helmet": "^8.1.0",
    "http-errors": "^2.0.1",
    "jsonwebtoken": "^9.0.3",
    "jwt-decode": "^4.0.0",
    "nocache": "^4.0.0",
    "nunjucks": "^3.2.4",
    "passport": "^0.7.0",
    "passport-oauth2": "^1.8.0",
    "redis": "^5.12.1",
    "superagent": "^10.3.0"
  },
  "devDependencies": {
    "@jgoz/esbuild-plugin-typecheck": "^4.0.4",
    "@ministryofjustice/eslint-config-hmpps": "^1.0.3",
    "@ministryofjustice/frontend-types": "1.0.0",
    "@ministryofjustice/hmpps-npm-script-allowlist": "0.0.4",
    "@ministryofjustice/hmpps-precommit-hooks": "2.0.2",
    "@tsconfig/node24": "^24.0.4",
    "@types/bunyan": "^1.8.11",
    "@types/bunyan-format": "^0.2.9",
    "@types/compression": "^1.8.1",
    "@types/connect-flash": "0.0.40",
    "@types/cookie-session": "^2.0.49",
    "@types/express-session": "^1.19.0",
    "@types/http-errors": "^2.0.5",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.11.0",
    "@types/nunjucks": "^3.2.6",
    "@types/passport": "^1.0.17",
    "@types/passport-oauth2": "^1.8.0",
    "@types/superagent": "^8.1.9",
    "@types/supertest": "^7.2.0",
    "audit-ci": "^7.1.0",
    "concurrently": "^9.2.1",
    "cypress": "^15.14.1",
    "cypress-multi-reporters": "^2.0.5",
    "del": "8.0.1",
    "esbuild": "^0.28.0",
    "esbuild-plugin-copy": "^2.1.1",
    "esbuild-plugin-manifest": "^1.0.5",
    "esbuild-sass-plugin": "^3.7.0",
    "jest": "^30.3.0",
    "jest-html-reporter": "^4.4.0",
    "jest-junit": "^17.0.0",
    "jsonwebtoken": "^9.0.3",
    "lint-staged": "^16.4.0",
    "nock": "^14.0.13",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3",
    "wiremock": "^3.13.2"
  },
  "overrides": {
    "brace-expansion": "^5.0.5",
    "diff": "^8.0.3",
    "serialize-javascript": "^7.0.3"
  }
}
